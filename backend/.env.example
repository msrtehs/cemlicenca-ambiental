# Banco de Dados
DATABASE_URL="postgresql://cemlicenca:senha_segura@localhost:5432/cemlicenca_db?schema=public"

# JWT
JWT_SECRET="sua_chave_secreta_aqui_mude_em_producao"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=development

# Gov.br OAuth (solicitar credenciais em https://manual.govbr.economia.gov.br/)
GOVBR_CLIENT_ID=""
GOVBR_CLIENT_SECRET=""
GOVBR_REDIRECT_URI="http://localhost:3001/api/auth/govbr/callback"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# WhatsApp API (ex: Twilio ou Z-API)
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# Frontend URL
FRONTEND_URL="http://localhost:5173"
